# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EXA_API_KEY=...

# ── Optional overrides ────────────────────────────────────────────────────────
MODEL=gpt-4o-mini
EXA_BASE_URL=https://api.exa.ai

# Comma-separated list of allowed CORS origins (default: *)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# CrewAI agent limits
AGENT_MAX_RPM=150
AGENT_MAX_ITER=15

# Max jobs kept in memory before oldest are evicted
MAX_JOBS_IN_MEMORY=100
